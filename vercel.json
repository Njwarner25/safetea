{
    "cleanUrls": true,
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
                { "key": "X-DNS-Prefetch-Control", "value": "off" },
                { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://apis.google.com https://cdnjs.cloudflare.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https: data:; connect-src 'self' https://*.googleapis.com https://nominatim.openstreetmap.org https://serpapi.com https://www.openstreetmap.org; frame-src https://www.openstreetmap.org https://www.google.com" }
            ]
        }
    ],
    "crons": [
        { "path": "/api/cron/cleanup-photos", "schedule": "0 3 * * *" },
        { "path": "/api/cron/fetch-crime-alerts", "schedule": "0 4 * * *" },
        { "path": "/api/cron/ai-moderate", "schedule": "*/30 * * * *" },
        { "path": "/api/cron/checkin-reminders", "schedule": "*/15 * * * *" },
        { "path": "/api/cron/expire-referrals", "schedule": "0 2 * * *" },
        { "path": "/api/cron/weekly-digest", "schedule": "0 18 * * 0" },
        { "path": "/api/cron/expire-org-access", "schedule": "0 5 * * *" }
    ],
    "rewrites": [
        { "source": "/api/screening/catfish", "destination": "/api/screening/catfish" },
