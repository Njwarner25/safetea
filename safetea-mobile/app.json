{
  "expo": {
    "name": "SafeTea",
    "slug": "safetea",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "safetea",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A2E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.getsafetea.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeTea uses your location to share your GPS coordinates with trusted contacts during an SOS alert.",
        "NSMicrophoneUsageDescription": "SafeTea uses the microphone for audio features.",
        "NSCameraUsageDescription": "SafeTea uses the camera for identity verification selfies.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "package": "app.getsafetea.mobile",
      "versionCode": 10
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "SafeTea uses the camera for identity verification selfies."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SafeTea uses your location to share your GPS coordinates with trusted contacts during an SOS alert."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "SafeTea uses the microphone for audio features."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E8A0B5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "13404653-99fa-49c1-af47-c981dbd27027"
      }
    }
  }
}
