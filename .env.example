# SafeTea Environment Variables
# Copy this file to .env.local and fill in your values

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-secret-key-here-change-in-production

# PII Encryption (separate key recommended; falls back to JWT_SECRET)
PII_ENCRYPTION_KEY=generate-a-separate-encryption-key

# PostgreSQL Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/safetea

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PLUS_PRICE_ID=price_your_plus_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App URL (for Stripe redirects and CORS)
APP_URL=https://getsafetea.app

# Migration secret (protect the /api/migrate endpoint)
MIGRATE_SECRET=your-migrate-secret-here

# Cron job secret (Vercel cron authorization)
CRON_SECRET=your-cron-secret-here

# Database Pool Scaling (increase as you upgrade Railway tier)
# Hobby: 20 | Starter: 50 | Pro: 100
DB_POOL_SIZE=20

# User threshold before scale alerts fire (logs warning to upgrade DB)
SCALE_ALERT_USER_THRESHOLD=500

# City activation threshold (votes needed to auto-unlock a city)
CITY_ACTIVATION_THRESHOLD=200

# Photo Watermarking (used to sign/verify watermarks — KEEP SECRET)
WATERMARK_SECRET=generate-a-random-secret-here

# Community Suggestions (votes needed to flag for product review)
SUGGESTION_VOTE_THRESHOLD=50

# AI Story Verification & Moderation (OpenAI API)
OPENAI_API_KEY=your-openai-api-key-here

# Twilio (SMS for SafeWalk, date check-ins, emergency alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1your-twilio-number

# Firebase (phone auth)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Screening APIs
SERPAPI_KEY=your-serpapi-key
BING_SEARCH_KEY=your-bing-search-key

# Google Custom Search (background check fallback)
GOOGLE_SEARCH_API_KEY=your-google-api-key
GOOGLE_SEARCH_CX=your-google-cx-id

# Didit Identity Verification (under separate audit)
DIDIT_API_KEY=your-didit-api-key
DIDIT_WORKFLOW_ID=your-didit-workflow-id
DIDIT_WEBHOOK_SECRET=your-didit-webhook-secret
