{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" },
                { "key": "X-DNS-Prefetch-Control", "value": "off" },
                { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://apis.google.com https://cdnjs.cloudflare.com https://www.gstatic.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' https: data:; connect-src 'self' https://*.googleapis.com https://nominatim.openstreetmap.org https://api.stripe.com https://www.openstreetmap.org; frame-src https://www.openstreetmap.org https://www.google.com https://js.stripe.com" }
            ]
        }
    ],
    "crons": [
        { "path": "/api/cron/cleanup-photos", "schedule": "0 3 * * *" },
        { "path": "/api/cron/fetch-crime-alerts", "schedule": "0 4 * * *" }
    ],
    "rewrites": [
        { "source": "/api/screening/redflag", "destination": "/api/screening/redflag" },
        { "source": "/api/screening/offender", "destination": "/api/screening/offender" },
        { "source": "/api/screening/catfish", "destination": "/api/screening/catfish" },
        { "source": "/api/screening/background", "destination": "/api/screening/background" },
        { "source": "/api/dates/checkout", "destination": "/api/dates/checkout" },
        { "source": "/api/dates/checkin", "destination": "/api/dates/checkin" },
        { "source": "/api/dates/status", "destination": "/api/dates/status" },
        { "source": "/api/dates/share", "destination": "/api/dates/share" },
        { "source": "/api/dates/report", "destination": "/api/dates/report" },
        { "source": "/api/blog/news", "destination": "/api/blog/news" },
        { "source": "/api/subscribe", "destination": "/api/subscribe" },
        { "source": "/api/webhook-stripe", "destination": "/api/webhook-stripe" },
        { "source": "/api/referral/track", "destination": "/api/referral/track" },
        { "source": "/api/referral", "destination": "/api/referral" },
        { "source": "/api/namewatch", "destination": "/api/namewatch" },
        { "source": "/api/refund", "destination": "/api/refund" },
        { "source": "/api/migrate-referrals", "destination": "/api/migrate-referrals" },
        { "source": "/api/posts/report", "destination": "/api/posts/report" },
        { "source": "/api/posts/removal-request", "destination": "/api/posts/removal-request" },
        { "source": "/api/posts/:id", "destination": "/api/posts/[id]" },
        { "source": "/api/users/ban", "destination": "/api/users/ban" },
        { "source": "/api/auth/change-password", "destination": "/api/auth/change-password" },
        { "source": "/api/auth/verify/:path*", "destination": "/api/auth/verify/:path*" },
        { "source": "/api/alerts/area", "destination": "/api/alerts/area" },
        { "source": "/api/watch-zones", "destination": "/api/watch-zones" },
        { "source": "/api/migrate-crime-alerts", "destination": "/api/migrate-crime-alerts" },
        { "source": "/api/cron/fetch-crime-alerts", "destination": "/api/cron/fetch-crime-alerts" },
        { "source": "/api/community/post", "destination": "/api/community/post" },
        { "source": "/api/community", "destination": "/api/community/index" },
        { "source": "/api/feedback", "destination": "/api/feedback" },
        { "source": "/api/posts/replies", "destination": "/api/posts/replies" },
        { "source": "/api/namewatch/:path*", "destination": "/api/namewatch" },
        { "source": "/api/photos/removal-public", "destination": "/api/photos/removal-public" },
        { "source": "/api/(.*)", "destination": "/api/$1" }
    ]
}
