{
  "name": "safetea-mobile-shell",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor native shell for SafeTea — loads getsafetea.app directly so iOS and Android are identical to web.",
  "scripts": {
    "sync": "cap sync",
    "ios": "cap open ios",
    "android": "cap open android",
    "assets:source": "node generate-native-assets.js",
    "assets": "node generate-native-assets.js && capacitor-assets generate --iconBackgroundColor '#F4D9E1' --iconBackgroundColorDark '#1A1A2E' --splashBackgroundColor '#1A1A2E' --splashBackgroundColorDark '#1A1A2E'",
    "build:ios": "cap sync ios && cap open ios",
    "build:android": "cap sync android && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/geolocation": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5"
  }
}
